<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://java.sun.com/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://java.sun.com/xml/ns/persistence
    http://java.sun.com/xml/ns/persistence/persistence_2_0.xsd"
             version="2.0">

  <persistence-unit name="simple-persistence-unit" transaction-type="RESOURCE_LOCAL">
    <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

    <class>ar.edu.utn.frba.dds.model.Hecho.Hecho</class>

    <class>ar.edu.utn.frba.dds.model.fuente.Fuente</class>
    <class>ar.edu.utn.frba.dds.model.fuente.FuenteDinamica</class>
    <class>ar.edu.utn.frba.dds.model.fuente.FuenteDemo</class>
    <class>ar.edu.utn.frba.dds.model.fuente.FuenteAgregadora</class>
    <class>ar.edu.utn.frba.dds.model.fuente.FuenteEstatica</class>
    <class>ar.edu.utn.frba.dds.model.fuente.FuenteMetaMapa</class>

    <class>ar.edu.utn.frba.dds.model.coleccion.Coleccion</class>

    <class>ar.edu.utn.frba.dds.model.criterio.Criterio</class>
    <class>ar.edu.utn.frba.dds.model.criterio.CriterioCumplidorSiempre</class>
    <class>ar.edu.utn.frba.dds.model.criterio.CriterioPorAntiguedad</class>
    <class>ar.edu.utn.frba.dds.model.criterio.CriterioPorCategoria</class>
    <class>ar.edu.utn.frba.dds.model.criterio.CriterioPorFechaCarga</class>
    <class>ar.edu.utn.frba.dds.model.criterio.CriterioPorRangoFecha</class>
    <class>ar.edu.utn.frba.dds.model.criterio.CriterioPorUbicacion</class>
    <class>ar.edu.utn.frba.dds.model.criterio.CriterioPorProvincia</class>

    <class>ar.edu.utn.frba.dds.model.Usuario.Usuario</class>

 <properties>
  <property name="hibernate.connection.driver_class"
            value="org.postgresql.Driver"/>

  <property name="hibernate.connection.url"
            value="${hibernate.connection.url}"/>

  <property name="hibernate.connection.username"
            value="${hibernate.connection.username}"/>

  <property name="hibernate.connection.password"
            value="${hibernate.connection.password}"/>

  <property name="hibernate.dialect"
            value="org.hibernate.dialect.PostgreSQLDialect"/>

  <property name="hibernate.hbm2ddl.auto" value="update"/>
  <property name="hibernate.show_sql" value="true"/>
</properties>


  </persistence-unit>

</persistence> 
